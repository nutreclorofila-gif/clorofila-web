{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "http://localhost/index.html",
        "http://localhost/curso.html",
        "http://localhost/servicios.html",
        "http://localhost/talleres.html",
        "http://localhost/leonardo.html",
        "http://localhost/articulos.html",
        "http://localhost/articulos/aceite-de-oliva-punto-de-humo.html",
        "http://localhost/sobre.html",
        "http://localhost/contacto.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
